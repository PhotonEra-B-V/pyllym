# pyllm provider credentials — copy to .env and fill in what you use.
# (pyllm does not auto-load .env; read it yourself, e.g. with python-dotenv,
#  then pass values via pyllm.configure.)

# OpenAI
OPENAI_API_KEY=
OPENAI_ORGANIZATION_ID=
OPENAI_PROJECT_ID=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# DeepSeek / Mistral / xAI / Perplexity / OpenRouter
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
OPENROUTER_API_KEY=

# Local
OLLAMA_API_BASE=http://localhost:11434/v1
GPUSTACK_API_BASE=

# Azure OpenAI
AZURE_API_BASE=
AZURE_API_KEY=

# AWS Bedrock
BEDROCK_API_KEY=
BEDROCK_SECRET_KEY=
BEDROCK_REGION=us-east-1
BEDROCK_SESSION_TOKEN=

# Vertex AI
VERTEXAI_PROJECT_ID=
VERTEXAI_LOCATION=us-central1
VERTEXAI_ACCESS_TOKEN=

# NVIDIA NIM / Cerebras / Hugging Face / Databricks (OpenAI-compatible)
NVIDIA_API_KEY=
CEREBRAS_API_KEY=
HUGGINGFACE_API_KEY=
DATABRICKS_API_BASE=
DATABRICKS_API_KEY=

# Qwen (DashScope) / Zhipu GLM / Moonshot Kimi / Doubao / ERNIE / MiniMax
QWEN_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
DOUBAO_API_KEY=
ERNIE_API_KEY=
MINIMAX_API_KEY=

# fal.ai (image + video generation)
FAL_API_KEY=
